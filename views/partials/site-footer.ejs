<button id="mv-chat-launcher" class="chat-launcher" type="button" aria-label="Chat öffnen">
  <i class="fa-regular fa-comments"></i>
</button>
<section id="mv-chat-panel" class="chat-panel" aria-live="polite" style="display:none;flex-direction:column;">
  <header class="chat-head">
    <h4>Kundenservice-Chat</h4>
    <button id="mv-chat-close" class="chat-close" type="button" aria-label="Chat schließen">&times;</button>
  </header>
  <div style="flex:1; min-height:420px; background:#fff;">
    <iframe
      id="mv-chat-iframe"
      title="MagicVics Chat"
      src="<%= magicvicsChatUrl %>"
      style="width:100%;height:100%;border:0;"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      allow="microphone; camera"
    ></iframe>
  </div>
</section>

<script>
(function initMagicvicsEmbeddedChat(){
  const launcher = document.getElementById('mv-chat-launcher');
  const panel = document.getElementById('mv-chat-panel');
  const closeBtn = document.getElementById('mv-chat-close');
  if (!launcher || !panel) return;

  const open = () => {
    panel.style.display = 'flex';
    panel.classList.add('open');
    launcher.style.display = 'none';
  };

  const close = () => {
    panel.classList.remove('open');
    panel.style.display = 'none';
    launcher.style.display = 'inline-flex';
  };

  launcher.addEventListener('click', open);
  closeBtn && closeBtn.addEventListener('click', close);
})();
</script>

