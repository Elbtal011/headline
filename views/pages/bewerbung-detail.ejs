<%- include('../partials/site-head', { title: `Headline Agentur | ${pageData.job.title}` }) %>
<%- include('../partials/site-header') %>

<section class="breadcrumb-wrapper">
  <div class="container">
    <div class="page-heading">
      <h1>Karriere</h1>
      <p>Headline Agentur Karriere & Stellen</p>
    </div>
  </div>
</section>

<section class="contact-wrapper section-padding pt-5">
  <div class="container">
    <% const job = pageData.job || {}; %>
    <% const jobFacts = job.facts || {}; %>
    <% const description = job.description || job.summary || ''; %>
    <% const requirements = (job.requirements && job.requirements.length ? job.requirements : job.profile) || []; %>
    <% const tasks = (job.tasks && job.tasks.length ? job.tasks : []) || []; %>
    <% const benefits = (job.benefits && job.benefits.length ? job.benefits : job.offer) || []; %>
    <% const employmentType = job.type_of_employment || job.employment_type || job.employmentType || jobFacts.employment || '-'; %>
    <% const workingModel = job.working_model || job.workingModel || '-'; %>
    <% const location = job.location || jobFacts.location || '-'; %>
    <% const salaryText = job.salary_display || job.salaryDisplay || job.ad_text || job.adText || jobFacts.salary || '-'; %>
    <% const salaryRange = ((job.min_salary || job.minSalary || job.max_salary || job.maxSalary) ? `${job.min_salary || job.minSalary || 0} - ${job.max_salary || job.maxSalary || 0} €` : '-'); %>
    <% const formatDate = (value) => { if (!value) return '-'; const d = new Date(value); if (Number.isNaN(d.getTime())) return value; const day = String(d.getDate()).padStart(2,'0'); const month = String(d.getMonth()+1).padStart(2,'0'); const year = d.getFullYear(); return `${day}.${month}.${year}`; }; %>
    <% const factDate = jobFacts.date || job.posted_at || job.postedAt || job.created_at || '-'; %>
    <% const factSalary = salaryText || jobFacts.salary || salaryRange || '-'; %>
    <% const factEmployment = jobFacts.employment || workingModel || employmentType || '-'; %>
    <% const factWeekly = jobFacts.weekly_hours || jobFacts.weeklyHours || job.weekly_hours || job.weeklyHours || '-'; %>
    <% const factDeadline = jobFacts.deadline || job.application_deadline || job.applicationDeadline || '-'; %>
    <% if (query.ok) { %>
      <div class="form-success">Vielen Dank. Ihre Bewerbung wurde erfolgreich uebermittelt.</div>
    <% } %>

    <div class="row g-4">
      <div class="col-xl-8 col-lg-7">
        <div class="codex-contact-items">
          <div style="margin-bottom:32px;">
            <h3 style="margin-bottom:20px;"><%= job.title %></h3>
            <% if (description) { %>
              <p style="margin-bottom:20px;"><%= description %></p>
            <% } %>

            <% if (tasks.length) { %>
              <h4 style="margin-bottom:12px;">Aufgaben</h4>
              <ul style="list-style:disc; padding-left:22px; margin-bottom:20px; line-height:1.8;">
                <% tasks.forEach((entry) => { %>
                  <li><%= entry %></li>
                <% }) %>
              </ul>
            <% } %>

            <% if (requirements.length) { %>
              <h4 style="margin-bottom:12px;">Anforderungen</h4>
              <ul style="list-style:disc; padding-left:22px; margin-bottom:20px; line-height:1.8;">
                <% requirements.forEach((entry) => { %>
                  <li><%= entry %></li>
                <% }) %>
              </ul>
            <% } %>

            <% if (benefits.length) { %>
              <h4 style="margin-bottom:12px;">Benefits</h4>
              <ul style="list-style:disc; padding-left:22px; margin-bottom:0; line-height:1.8;">
                <% benefits.forEach((entry) => { %>
                  <li><%= entry %></li>
                <% }) %>
              </ul>
            <% } %>
          </div>

          <div class="contact-form-box">
            <h2 style="font-size:clamp(34px, 8vw, 56px); line-height:1.08; margin-bottom:20px;">Auf diese Stelle bewerben!</h2>
            <p style="margin-bottom:28px;">Bewerben Sie sich jetzt fuer <strong>"<%= job.title %>"</strong>.</p>

            <form method="post" action="/api/leads/application">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="source_page" value="/Bewerbung/<%= job.slug %>" />
              <input type="hidden" name="job_title" value="<%= job.title %>" />
              <input type="text" name="website" class="hp" tabindex="-1" autocomplete="off" />

              <div class="row g-3">
                <div class="col-md-6"><div class="form-clt"><input name="name" required placeholder="Vor- und Nachname" type="text" /></div></div>
                <div class="col-md-6"><div class="form-clt"><input name="email" required placeholder="E-Mail Adresse" type="email" /></div></div>

                <div class="col-12"><div class="form-clt"><input name="address" required placeholder="Anschrift" type="text" /></div></div>

                <div class="col-md-4"><div class="form-clt"><input name="zip" required placeholder="Postleitzahl" type="text" /></div></div>
                <div class="col-md-8"><div class="form-clt"><input name="city" required placeholder="Stadt / Ort" type="text" /></div></div>

                <div class="col-12"><div class="form-clt"><input name="country" required placeholder="Staatsangehoerigkeit" type="text" /></div></div>
                <div class="col-12"><div class="form-clt"><input name="mobile" required placeholder="Mobilnummer" type="text" /></div></div>

                <div class="col-12">
                  <div class="form-clt">
                    <label for="qualidob" class="mb-2">Geburtsdatum</label>
                    <input id="qualidob" type="date" name="dob" required />
                  </div>
                </div>

                <div class="col-12" style="margin-top:18px;">
                  <button class="theme-btn" type="submit">Bewerbung absenden <i class="fa-solid fa-arrow-right"></i></button>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>

      <div class="col-xl-4 col-lg-5">
        <div class="codex-contact-items" style="padding:24px; background:#f1f4f6; border-radius:12px;">
          <h3 style="font-size:26px; line-height:1.25; margin:0 0 6px;">Zahlen & Fakten</h3>
          <div style="width:44px; height:3px; background:#111827; margin:8px 0 18px;"></div>
          <div style="display:grid; gap:14px;">
            <div style="display:flex; justify-content:space-between; gap:12px;"><span style="color:#4b5563; font-weight:600;">Ausgeschrieben:</span><strong><%= formatDate(factDate) %></strong></div>
            <div style="display:flex; justify-content:space-between; gap:12px;"><span style="color:#4b5563; font-weight:600;">Gehalt:</span><strong><%= factSalary %></strong></div>
            <div style="display:flex; justify-content:space-between; gap:12px;"><span style="color:#4b5563; font-weight:600;">Anstellung:</span><strong><%= factEmployment %></strong></div>
            <div style="display:flex; justify-content:space-between; gap:12px;"><span style="color:#4b5563; font-weight:600;">Wochenstunden:</span><strong><%= factWeekly %></strong></div>
            <div style="display:flex; justify-content:space-between; gap:12px;"><span style="color:#4b5563; font-weight:600;">Bewerbungsfrist:</span><strong><%= formatDate(factDeadline) %></strong></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/site-footer') %>

