<%- include('../partials/site-head', { title: 'Headline Agentur | Registrierung' }) %>
<%- include('../partials/site-header') %>

<section class="breadcrumb-wrapper">
  <div class="container">
    <div class="page-heading">
      <h1>Registrierung</h1>
    </div>
  </div>
</section>

<section class="section-padding">
  <div class="container account-shell">
    <div class="account-card">
      <h3>Einrichtung Ihres Mitarbeiterzugangs</h3>
      <p class="account-muted">Richten Sie Ihr persönliches Mitarbeiterkonto ein, um Zugriff auf Ihre Aufgaben, Ihr Dashboard und interne Unternehmensfunktionen zu erhalten.</p>
      <% if (error) { %>
        <div class="alert error"><%= error %></div>
      <% } %>

      <div class="register-steps" aria-label="Registrierungsschritte">
        <div class="register-step is-active" data-step-label="1"><span>1</span><small>Persönliche Daten</small></div>
        <div class="register-step" data-step-label="2"><span>2</span><small>Adresse</small></div>
        <div class="register-step" data-step-label="3"><span>3</span><small>Vertrag</small></div>
      </div>

      <form method="post" action="/konto/registrieren" id="register-form" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="signature_data" id="signature-data" value="" />

        <div class="register-pane is-active" data-step="1">
          <div class="account-form-grid">
            <div class="account-field full"><label for="reg-email">E-Mail</label><input id="reg-email" name="email" type="email" required value="<%= values.email || '' %>" /></div>
            <div class="account-field"><label for="reg-pass">Passwort (mind. 8 Zeichen)</label><input id="reg-pass" name="password" type="password" minlength="8" required /></div>
            <div class="account-field"><label for="reg-pass-confirm">Passwort bestätigen</label><input id="reg-pass-confirm" name="password_confirm" type="password" minlength="8" required /></div>
            <div class="account-field"><label for="reg-first">Vorname</label><input id="reg-first" name="first_name" required value="<%= values.first_name || '' %>" /></div>
            <div class="account-field"><label for="reg-last">Nachname</label><input id="reg-last" name="last_name" required value="<%= values.last_name || '' %>" /></div>
            <div class="account-field full"><label for="reg-phone">Telefonnummer</label><input id="reg-phone" name="phone" required value="<%= values.phone || '' %>" /></div>
            <div class="account-field full"><label for="reg-birth">Geburtsdatum</label><input id="reg-birth" name="birth_date" type="date" value="<%= values.birth_date || '' %>" /></div>
          </div>
          <div class="account-actions">
            <button class="theme-btn" type="button" data-next-step="2">Weiter <i class="fa-solid fa-arrow-right"></i></button>
          </div>
        </div>

        <div class="register-pane" data-step="2">
          <div class="account-form-grid">
            <div class="account-field full"><label for="reg-address">Anschrift</label><input id="reg-address" name="address_line" value="<%= values.address_line || '' %>" /></div>
            <div class="account-field"><label for="reg-zip">PLZ</label><input id="reg-zip" name="zip" value="<%= values.zip || '' %>" /></div>
            <div class="account-field"><label for="reg-city">Stadt</label><input id="reg-city" name="city" value="<%= values.city || '' %>" /></div>
            <div class="account-field full"><label for="reg-country">Land</label><input id="reg-country" name="country" value="<%= values.country || 'Deutschland' %>" /></div>
          </div>
          <div class="account-actions">
            <button class="theme-btn register-back-btn" type="button" data-prev-step="1">Zurück</button>
            <button class="theme-btn" type="button" data-next-step="3">Weiter <i class="fa-solid fa-arrow-right"></i></button>
          </div>
        </div>

        <div class="register-pane" data-step="3">
          <div class="register-contract-box">
            <h4>Vertragsbestätigung</h4>
            <p>Mit Ihrer Unterschrift bestätigen Sie die Richtigkeit Ihrer Angaben und stimmen der Einrichtung Ihres Mitarbeiterzugangs zu.</p>
            <label class="register-consent">
              <input type="checkbox" id="contract-accepted" name="contract_accepted" value="1" required />
              <span>Ich stimme den Vertragsbedingungen und der Datenverarbeitung zu.</span>
            </label>
          </div>

          <div class="register-signature-wrap">
            <div class="register-signature-head">
              <label for="signature-pad">Unterschrift</label>
              <button type="button" class="register-clear-signature" id="clear-signature">Unterschrift löschen</button>
            </div>
            <canvas id="signature-pad" width="900" height="220" aria-label="Unterschrift"></canvas>
            <p class="register-signature-hint">Bitte unterschreiben Sie im Feld (mit Maus oder Touch).</p>
            <p class="register-signature-error" id="signature-error" hidden>Bitte Unterschrift hinzufügen.</p>
          </div>

          <div class="account-field full" style="margin-top:14px;">
            <label for="reg-captcha">Sicherheitsfrage: <span class="captcha-pill"><%= captchaQuestion %></span></label>
            <input id="reg-captcha" name="captcha_answer" required />
          </div>

          <div class="account-actions">
            <button class="theme-btn register-back-btn" type="button" data-prev-step="2">Zurück</button>
            <button class="theme-btn" type="submit">Registrierung abschließen <i class="fa-solid fa-arrow-right"></i></button>
          </div>
        </div>
      </form>

      <p class="account-links">Bereits registriert? <a href="/konto/login">Zum Login</a></p>
    </div>
  </div>
</section>

<style>
  .register-steps{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;margin:0 0 22px}
  .register-step{border:1px solid #d2dfec;background:#f7fbff;border-radius:12px;padding:10px 12px;display:flex;align-items:center;gap:10px;color:#4b647f}
  .register-step span{width:26px;height:26px;border-radius:999px;background:#dce9f7;color:#2b4f74;font-weight:700;display:flex;align-items:center;justify-content:center;font-size:13px}
  .register-step small{font-size:13px;font-weight:600}
  .register-step.is-active{border-color:#9fbee0;background:#eaf3fd;color:#103e67}
  .register-step.is-active span{background:#0d4f9b;color:#fff}
  .register-pane{display:none}
  .register-pane.is-active{display:block}
  .register-contract-box{border:1px solid #d7e2ee;background:#f9fcff;border-radius:12px;padding:14px 14px 10px;margin-bottom:12px}
  .register-contract-box h4{margin:0 0 8px;color:#0f2f4f}
  .register-contract-box p{margin:0 0 10px;color:#496685;font-size:14px}
  .register-consent{display:flex;gap:10px;align-items:center;font-size:14px;color:#1d3958;line-height:1.35}
  .register-consent input{margin:0;position:relative;top:0;flex:0 0 auto}
  .register-signature-wrap{border:1px solid #d2dfec;border-radius:12px;padding:12px;background:#fff}
  .register-signature-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
  .register-signature-head label{font-weight:700;color:#1f3551;margin:0}
  .register-clear-signature{border:0;background:transparent;color:#0d4f9b;font-weight:600;padding:0;cursor:pointer}
  #signature-pad{width:100%;height:180px;border:1px dashed #b9cee3;border-radius:10px;background:#fcfeff;touch-action:none}
  .register-signature-hint{margin:8px 0 0;font-size:13px;color:#5a7490}
  .register-signature-error{margin:8px 0 0;color:#c12525;font-size:13px;font-weight:600}
  .register-back-btn{
    background:#e9f1fb !important;
    color:#0d4f9b !important;
    border:1px solid #b9d0e8 !important;
    box-shadow:none !important;
    min-width:112px;
    min-height:52px;
    padding:0 20px !important;
    border-radius:999px !important;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    font-weight:700;
  }
  .register-back-btn:hover{background:#dceafb !important; color:#0b447f !important;}
</style>

<script>
(function(){
  const form = document.getElementById('register-form');
  if (!form) return;

  const panes = Array.from(form.querySelectorAll('.register-pane'));
  const steps = Array.from(document.querySelectorAll('.register-step'));
  const password = document.getElementById('reg-pass');
  const passwordConfirm = document.getElementById('reg-pass-confirm');

  let onStepChanged = null;
  function setStep(step){
    panes.forEach((pane)=>pane.classList.toggle('is-active', pane.dataset.step === String(step)));
    steps.forEach((node, idx)=>node.classList.toggle('is-active', idx + 1 === Number(step)));
    if (typeof onStepChanged === 'function') onStepChanged(Number(step));
  }

  function validateCurrentStep(step){
    const pane = panes.find((p)=>p.dataset.step === String(step));
    if (!pane) return true;
    const fields = Array.from(pane.querySelectorAll('input, select, textarea'));

    if (String(step) === '1' && password && passwordConfirm) {
      if (password.value !== passwordConfirm.value) {
        passwordConfirm.setCustomValidity('Passwörter stimmen nicht überein.');
      } else {
        passwordConfirm.setCustomValidity('');
      }
    }

    for (const field of fields) {
      if (!field.checkValidity()) {
        field.reportValidity();
        return false;
      }
    }
    return true;
  }

  form.querySelectorAll('[data-next-step]').forEach((btn)=>{
    btn.addEventListener('click', ()=>{
      const current = Number(btn.getAttribute('data-next-step')) - 1;
      if (!validateCurrentStep(current)) return;
      setStep(btn.getAttribute('data-next-step'));
    });
  });

  form.querySelectorAll('[data-prev-step]').forEach((btn)=>{
    btn.addEventListener('click', ()=> setStep(btn.getAttribute('data-prev-step')));
  });

  const canvas = document.getElementById('signature-pad');
  const signatureInput = document.getElementById('signature-data');
  const signatureError = document.getElementById('signature-error');
  const clearBtn = document.getElementById('clear-signature');
  let hasSignature = false;

  if (canvas && signatureInput) {
    const ctx = canvas.getContext('2d');
    let drawing = false;

    function resizeCanvas() {
      const rect = canvas.getBoundingClientRect();
      const holder = canvas.parentElement || canvas;
      const fallbackW = holder.clientWidth || 900;
      const fallbackH = 180;
      const cssW = Math.max(1, Math.floor(rect.width || fallbackW));
      const cssH = Math.max(1, Math.floor(rect.height || fallbackH));
      const ratio = Math.max(window.devicePixelRatio || 1, 1);
      canvas.width = Math.floor(cssW * ratio);
      canvas.height = Math.floor(cssH * ratio);
      ctx.setTransform(1, 0, 0, 1, 0, 0);
      ctx.scale(ratio, ratio);
      ctx.lineWidth = 2;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
      ctx.strokeStyle = '#102947';
    }

    function pointFromEvent(evt) {
      const rect = canvas.getBoundingClientRect();
      const touch = evt && evt.touches && evt.touches[0] ? evt.touches[0] : (evt && evt.changedTouches && evt.changedTouches[0] ? evt.changedTouches[0] : null);
      const source = touch || evt;
      return { x: source.clientX - rect.left, y: source.clientY - rect.top };
    }

    function start(evt) {
      if (!canvas.width || !canvas.height) resizeCanvas();
      drawing = true;
      if (canvas.setPointerCapture && evt.pointerId != null) canvas.setPointerCapture(evt.pointerId);
      const p = pointFromEvent(evt);
      ctx.beginPath();
      ctx.moveTo(p.x, p.y);
      if (evt && evt.preventDefault) evt.preventDefault();
    }

    function move(evt) {
      if (!drawing) return;
      const p = pointFromEvent(evt);
      ctx.lineTo(p.x, p.y);
      ctx.stroke();
      hasSignature = true;
      signatureInput.value = canvas.toDataURL('image/png');
      if (signatureError) signatureError.hidden = true;
      if (evt && evt.preventDefault) evt.preventDefault();
    }

    function stop(evt) {
      drawing = false;
      if (canvas.releasePointerCapture && evt && evt.pointerId != null) {
        try { canvas.releasePointerCapture(evt.pointerId); } catch (_) {}
      }
      if (evt && evt.preventDefault) evt.preventDefault();
    }

    resizeCanvas();
    onStepChanged = function(step){
      if (Number(step) === 3) {
        setTimeout(resizeCanvas, 0);
      }
    };
    window.addEventListener('resize', resizeCanvas);

    canvas.addEventListener('pointerdown', start, { passive: false });
    canvas.addEventListener('pointermove', move, { passive: false });
    canvas.addEventListener('pointerup', stop, { passive: false });
    canvas.addEventListener('pointercancel', stop, { passive: false });
    canvas.addEventListener('pointerleave', stop, { passive: false });

    canvas.addEventListener('mousedown', start, { passive: false });
    canvas.addEventListener('mousemove', move, { passive: false });
    canvas.addEventListener('mouseup', stop, { passive: false });
    canvas.addEventListener('mouseleave', stop, { passive: false });

    canvas.addEventListener('touchstart', start, { passive: false });
    canvas.addEventListener('touchmove', move, { passive: false });
    canvas.addEventListener('touchend', stop, { passive: false });
    canvas.addEventListener('touchcancel', stop, { passive: false });

    if (clearBtn) {
      clearBtn.addEventListener('click', ()=>{
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        hasSignature = false;
        signatureInput.value = '';
      });
    }

    form.addEventListener('submit', (evt)=>{
      if (!validateCurrentStep(3)) {
        evt.preventDefault();
        return;
      }
      if (!hasSignature || !signatureInput.value) {
        evt.preventDefault();
        if (signatureError) signatureError.hidden = false;
      }
    });
  }
})();
</script>

<%- include('../partials/site-footer') %>
