<%- include('../partials/site-head', { title: 'Headline Agentur | Registrierung' }) %>
<%- include('../partials/site-header') %>

<section class="breadcrumb-wrapper">
  <div class="container">
    <div class="page-heading">
      <h1>Registrierung</h1>
    </div>
  </div>
</section>

<section class="section-padding">
  <div class="container account-shell">
    <div class="account-card" style="max-width:700px;margin:0 auto;">
      <h3>Konto einrichten</h3>
      <p class="account-muted">Bitte ergänzen Sie Ihre Daten und setzen Sie ein Passwort.</p>
      <% if (error) { %>
        <div class="alert error"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert success"><%= success %></div>
      <% } %>
      <form method="post" action="/konto/registrieren">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="account-form-grid">
          <div class="account-field">
            <label for="register-first-name">Vorname</label>
            <input id="register-first-name" name="first_name" type="text" value="<%= values.first_name || '' %>" required />
          </div>
          <div class="account-field">
            <label for="register-last-name">Nachname</label>
            <input id="register-last-name" name="last_name" type="text" value="<%= values.last_name || '' %>" required />
          </div>
          <div class="account-field full">
            <label for="register-email">E-Mail-Adresse</label>
            <input id="register-email" name="email" type="email" value="<%= values.email || '' %>" required />
          </div>
          <div class="account-field full">
            <label for="register-phone">Telefonnummer</label>
            <input id="register-phone" name="phone" type="text" value="<%= values.phone || '' %>" required />
          </div>
          <div class="account-field full">
            <label for="register-password">Passwort</label>
            <input id="register-password" name="password" type="password" required />
          </div>
          <div class="account-field full">
            <label for="register-password-confirm">Passwort bestätigen</label>
            <input id="register-password-confirm" name="password_confirm" type="password" required />
          </div>
          <div class="account-field full">
            <label for="register-captcha">Sicherheitsfrage: <span class="captcha-pill"><%= captchaQuestion %></span></label>
            <input id="register-captcha" name="captcha_answer" type="text" required />
          </div>
          <div class="account-actions">
            <button class="theme-btn" type="submit">Registrierung abschließen <i class="fa-solid fa-arrow-right"></i></button>
          </div>
        </div>
      </form>
    </div>
  </div>
</section>

<%- include('../partials/site-footer') %>
