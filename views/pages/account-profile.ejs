<%- include('../partials/site-head', { title: 'Headline Agentur | Mein Profil' }) %>
<%- include('../partials/site-header') %>

<section class="breadcrumb-wrapper">
  <div class="container">
    <div class="page-heading">
      <h1>Mein Profil</h1>
      <p>Konto verwalten</p>
    </div>
  </div>
</section>

<section class="section-padding">
  <div class="container account-shell <%= activeTab === 'dashboard' ? 'account-shell--wide' : '' %>">
    <% const birthDateInput = (() => {
      if (!user || !user.birth_date) return '';
      const raw = user.birth_date;
      if (typeof raw === 'string') return raw.slice(0, 10);
      const d = new Date(raw);
      if (Number.isNaN(d.getTime())) return '';
      const y = d.getUTCFullYear();
      const m = String(d.getUTCMonth() + 1).padStart(2, '0');
      const day = String(d.getUTCDate()).padStart(2, '0');
      return `${y}-${m}-${day}`;
    })(); %>
    <div class="account-layout account-layout--dashboard">
      <div class="account-card" style="max-width:none;">
        <% if (success) { %>
          <div class="alert success"><%= success %></div>
        <% } %>
        <% if (error) { %>
          <div class="alert error"><%= error %></div>
        <% } %>

        <% const dash = dashboard || { totalApplications: 0, openApplications: 0, inReviewApplications: 0, closedApplications: 0, latestApplications: [], documentsCount: 0, profileCompletion: 0 }; %>
        <% if (activeTab === 'dashboard') { %>
          <section class="mockdash">
            <aside class="mockdash-side">
              <div class="mockdash-brand">Headline</div>
              <nav class="mockdash-menu">
                <a class="active" href="/konto/profil?tab=dashboard">Dashboard</a>
                <a href="/konto/profil?tab=tasks">Aufgaben <span class="dot"><%= dash.openApplications %></span></a>
                <a href="/konto/profil?tab=earnings">Einnahmen</a>
                <a href="/konto/profil?tab=profile">Profil</a>
                <a href="/konto/profil?tab=support">Support</a>
              </nav>
              <div class="mockdash-user">
                <strong><%= [user.first_name, user.last_name].filter(Boolean).join(' ') || 'User' %></strong>
                <small><%= user.email %></small>
              </div>
            </aside>

            <div class="mockdash-main">
              <header class="mockdash-head">
                <h3>Willkommen zurück, <%= user.first_name || 'User' %>!</h3>
                <p>Hier sind deine Aufgaben und dein Kontostand.</p>
              </header>

              <section class="mockdash-tasks">
                <div class="mockdash-card-head">
                  <h4>Deine Aufgaben</h4>
                  <a href="/Bewerbung" class="dash-link">+ Neue Bewerbung</a>
                </div>
                <div class="mockdash-tabs">
                  <span class="active">Offen</span>
                  <span>In Prüfung</span>
                  <span>Akzeptiert</span>
                  <span>Archiviert</span>
                </div>
                <div class="mockdash-table">
                  <% if (!dash.latestApplications || dash.latestApplications.length === 0) { %>
                    <p class="account-muted" style="margin:0;">Noch keine Aufgaben/Bewerbungen vorhanden.</p>
                  <% } else { %>
                    <% dash.latestApplications.forEach((app) => { %>
                      <article class="mockdash-row">
                        <div>
                          <strong><%= app.source_page || 'Bewerbung' %></strong>
                          <small><%= new Date(app.created_at).toLocaleDateString('de-DE') %></small>
                        </div>
                        <span class="badge"><%= app.status %></span>
                      </article>
                    <% }) %>
                  <% } %>
                </div>
              </section>
            </div>

            <aside class="mockdash-right">
              <section class="mockdash-balance">
                <h4>Kontostand</h4>
                <strong class="amount">EUR <%= (dash.closedApplications * 30).toFixed(2) %></strong>
                <p><%= dash.closedApplications %> erledigte Einträge · Profil <%= dash.profileCompletion %>%</p>
                <button class="theme-btn" type="button">Auszahlung beantragen</button>
              </section>

              <section class="mockdash-payments">
                <h4>Letzte Zahlungen</h4>
                <% if (!dash.latestApplications || dash.latestApplications.length === 0) { %>
                  <p class="account-muted" style="margin:0;">Noch keine Zahlungen vorhanden.</p>
                <% } else { %>
                  <% dash.latestApplications.slice(0, 3).forEach((app, idx) => { %>
                    <div class="payment-item">
                      <strong>EUR <%= (idx === 0 ? 30 : idx === 1 ? 25 : 20).toFixed(2) %></strong>
                      <small><%= app.source_page || 'Bewerbung' %> · <%= new Date(app.created_at).toLocaleDateString('de-DE') %></small>
                    </div>
                  <% }) %>
                <% } %>
              </section>
            </aside>
          </section>

        <% } else { %>
          <section class="mockdash">
            <aside class="mockdash-side">
              <div class="mockdash-brand">Headline</div>
              <nav class="mockdash-menu">
                <a href="/konto/profil?tab=dashboard">Dashboard</a>
                <a class="<%= activeTab === 'tasks' ? 'active' : '' %>" href="/konto/profil?tab=tasks">Aufgaben <span class="dot"><%= dash.openApplications %></span></a>
                <a class="<%= activeTab === 'earnings' ? 'active' : '' %>" href="/konto/profil?tab=earnings">Einnahmen</a>
                <a class="<%= activeTab === 'profile' ? 'active' : '' %>" href="/konto/profil?tab=profile">Profil</a>
                <a class="<%= activeTab === 'support' ? 'active' : '' %>" href="/konto/profil?tab=support">Support</a>
                <a class="<%= activeTab === 'documents' ? 'active' : '' %>" href="/konto/profil?tab=documents">Dokumente</a>
              </nav>
              <div class="mockdash-user">
                <strong><%= [user.first_name, user.last_name].filter(Boolean).join(' ') || 'User' %></strong>
                <small><%= user.email %></small>
              </div>
            </aside>

            <div class="mockdash-main">
              <% if (activeTab === 'tasks') { %>
                <header class="account-card-head"><h3>Aufgaben</h3><p class="account-muted">Aufgabenbereich ist vorbereitet.</p></header>
                <section class="mockdash-tasks"><p class="account-muted" style="margin:0;">Hier folgen deine Live-Aufgaben im nächsten Schritt.</p></section>
              <% } else if (activeTab === 'earnings') { %>
                <header class="account-card-head"><h3>Einnahmen</h3><p class="account-muted">Einnahmenbereich ist vorbereitet.</p></header>
                <section class="mockdash-tasks"><p class="account-muted" style="margin:0;">Hier folgen Kontostand/Verlauf mit Live-Daten.</p></section>
              <% } else if (activeTab === 'support') { %>
                <header class="account-card-head"><h3>Support</h3><p class="account-muted">Supportbereich</p></header>
                <section class="mockdash-tasks"><p class="account-muted" style="margin:0;">Kontakt: <a href="/Kontakt">/Kontakt</a></p></section>
              <% } else if (activeTab === 'profile') { %>
                <header class="account-card-head">
                  <h3>Persönliche Daten</h3>
                  <p class="account-muted">Pflegen Sie Ihre Kontaktdaten und halten Sie Ihr Profil aktuell.</p>
                </header>
                <form method="post" action="/konto/profil">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <h4 class="account-section-title">Basisdaten</h4>
                  <div class="account-form-grid">
                    <div class="account-field"><label for="pf-first">Vorname</label><input id="pf-first" name="first_name" required value="<%= user.first_name || '' %>" /></div>
                    <div class="account-field"><label for="pf-last">Nachname</label><input id="pf-last" name="last_name" required value="<%= user.last_name || '' %>" /></div>
                    <div class="account-field"><label for="pf-email">E-Mail</label><input id="pf-email" name="email" type="email" required value="<%= user.email || '' %>" /></div>
                    <div class="account-field"><label for="pf-phone">Telefon</label><input id="pf-phone" name="phone" value="<%= user.phone || '' %>" /></div>
                    <div class="account-field"><label for="pf-birth">Geburtsdatum</label><input id="pf-birth" name="birth_date" type="date" value="<%= birthDateInput %>" /></div>
                    <div class="account-field"><label for="pf-pass">Neues Passwort (optional)</label><input id="pf-pass" name="new_password" type="password" /></div>
                  </div>
                  <h4 class="account-section-title">Adressdaten</h4>
                  <div class="account-form-grid">
                    <div class="account-field full"><label for="pf-address">Anschrift</label><input id="pf-address" name="address_line" value="<%= user.address_line || '' %>" /></div>
                    <div class="account-field"><label for="pf-zip">PLZ</label><input id="pf-zip" name="zip" value="<%= user.zip || '' %>" /></div>
                    <div class="account-field"><label for="pf-city">Stadt</label><input id="pf-city" name="city" value="<%= user.city || '' %>" /></div>
                    <div class="account-field"><label for="pf-country">Land</label><input id="pf-country" name="country" value="<%= user.country || '' %>" /></div>
                  </div>
                  <div class="account-actions account-actions-end"><button class="theme-btn" type="submit">Profil speichern <i class="fa-solid fa-arrow-right"></i></button></div>
                </form>
              <% } else { %>
                <header class="account-card-head">
                  <h3>Dokumente</h3>
                  <p class="account-muted">Laden Sie angeforderte Unterlagen hoch, zum Beispiel Ausweis oder Gehaltsnachweise.</p>
                </header>
                <form method="post" action="/konto/profil/dokumente?_csrf=<%= encodeURIComponent(csrfToken) %>" enctype="multipart/form-data">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <div class="account-form-grid">
                    <div class="account-field">
                      <label for="doc-type">Dokumenttyp</label>
                      <select id="doc-type" name="doc_type" required>
                        <option value="">Bitte wählen</option>
                        <% docTypeOptions.forEach((opt) => { %>
                          <option value="<%= opt.value %>"><%= opt.label %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="account-field">
                      <label for="doc-file">Datei (PDF/JPG/PNG/WEBP, max. 10 MB)</label>
                      <input id="doc-file" name="document_file" type="file" required />
                    </div>
                    <div class="account-actions">
                      <button class="theme-btn" type="submit">Dokument hochladen <i class="fa-solid fa-arrow-up-from-bracket"></i></button>
                    </div>
                  </div>
                </form>
                <div class="account-doc-list">
                  <% if (!documents || documents.length === 0) { %>
                    <p class="account-muted" style="margin-top:14px;">Noch keine Dokumente hochgeladen.</p>
                  <% } else { %>
                    <% documents.forEach((doc) => { %>
                      <article class="account-doc-item">
                        <div>
                          <h5><%= doc.doc_type_label %></h5>
                          <p><%= doc.original_name %></p>
                          <small><%= new Date(doc.created_at).toLocaleString('de-DE') %> · <%= Math.ceil(doc.size_bytes / 1024) %> KB</small>
                        </div>
                        <a class="btn btn-secondary" href="<%= doc.file_url %>" target="_blank" rel="noopener noreferrer">Ansehen</a>
                      </article>
                    <% }) %>
                  <% } %>
                </div>
              <% } %>
            </div>

            <aside class="mockdash-right">
              <section class="mockdash-balance">
                <h4>Kontostand</h4>
                <strong class="amount">EUR <%= (dash.closedApplications * 30).toFixed(2) %></strong>
                <p><%= dash.closedApplications %> erledigte Einträge · Profil <%= dash.profileCompletion %>%</p>
                <button class="theme-btn" type="button">Auszahlung beantragen</button>
              </section>
              <section class="mockdash-payments">
                <h4>Letzte Zahlungen</h4>
                <% if (!dash.latestApplications || dash.latestApplications.length === 0) { %>
                  <p class="account-muted" style="margin:0;">Noch keine Zahlungen vorhanden.</p>
                <% } else { %>
                  <% dash.latestApplications.slice(0, 3).forEach((app, idx) => { %>
                    <div class="payment-item">
                      <strong>EUR <%= (idx === 0 ? 30 : idx === 1 ? 25 : 20).toFixed(2) %></strong>
                      <small><%= app.source_page || 'Bewerbung' %> · <%= new Date(app.created_at).toLocaleDateString('de-DE') %></small>
                    </div>
                  <% }) %>
                <% } %>
              </section>
            </aside>
          </section>
        <% } %>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/site-footer') %>
