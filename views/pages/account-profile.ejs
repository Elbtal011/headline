<%- include('../partials/site-head', { title: 'Headline Agentur | Mein Profil' }) %>
<%- include('../partials/site-header') %>

<section class="breadcrumb-wrapper">
  <div class="container">
    <div class="page-heading">
      <h1>Mein Profil</h1>
      <p>Konto verwalten</p>
    </div>
  </div>
</section>

<section class="section-padding">
  <div class="container account-shell account-shell--wide">
    <% const birthDateInput = (() => {
      if (!user || !user.birth_date) return '';
      const raw = user.birth_date;
      if (typeof raw === 'string') return raw.slice(0, 10);
      const d = new Date(raw);
      if (Number.isNaN(d.getTime())) return '';
      const y = d.getUTCFullYear();
      const m = String(d.getUTCMonth() + 1).padStart(2, '0');
      const day = String(d.getUTCDate()).padStart(2, '0');
      return `${y}-${m}-${day}`;
    })(); %>
    <% const formatRemaining = (dueRaw) => {
      if (!dueRaw) return 'Unbegrenzt';
      const due = new Date(dueRaw);
      if (Number.isNaN(due.getTime())) return 'Unbegrenzt';
      const diff = due.getTime() - Date.now();
      if (diff <= 0) return 'Abgelaufen';
      const mins = Math.floor(diff / 60000);
      const days = Math.floor(mins / 1440);
      const hours = Math.floor((mins % 1440) / 60);
      const minutes = mins % 60;
      if (days > 0) return `${days}d ${hours}h ${minutes}m`;
      if (hours > 0) return `${hours}h ${minutes}m`;
      return `${minutes}m`;
    }; %>
    <div class="account-layout account-layout--dashboard">
      <div class="account-card" style="max-width:none;">
        <% if (success) { %>
          <div class="alert success"><%= success %></div>
        <% } %>
        <% if (error) { %>
          <div class="alert error"><%= error %></div>
        <% } %>

        <% const dash = dashboard || { totalApplications: 0, openApplications: 0, inReviewApplications: 0, closedApplications: 0, latestApplications: [], latestPayouts: [], assignedTasks: [], openTasks: 0, completedTasks: 0, earnedAmount: 0, totalEarnedAmount: 0, pendingPayoutAmount: 0, documentsCount: 0, profileCompletion: 0 }; %>
        <% if (activeTab === 'dashboard') { %>
          <section class="mockdash">
            <aside class="mockdash-side">
              <nav class="mockdash-menu">
                <a class="active" href="/konto/profil?tab=dashboard">Dashboard</a>
                <a href="/konto/profil?tab=tasks">Aufgaben <span class="dot"><%= dash.openTasks %></span></a>
                <a href="/konto/profil?tab=earnings">Einnahmen</a>
                <a href="/konto/profil?tab=profile">Profil</a>
                <a href="/konto/profil?tab=support">Support</a>
                <a href="/konto/profil?tab=documents">Dokumente</a>
              </nav>
              <div class="mockdash-user">
                <strong><%= [user.first_name, user.last_name].filter(Boolean).join(' ') || 'User' %></strong>
                <small><%= user.email %></small>
                <form method="post" action="/konto/logout" class="mockdash-logout-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="mockdash-logout-btn">Logout</button>
                </form>
              </div>
            </aside>

            <div class="mockdash-main">
              <header class="mockdash-head">
                <h3>Willkommen zurück, <%= user.first_name || 'User' %>!</h3>
                <p>Hier sind deine Aufgaben und dein Kontostand.</p>
              </header>

              <section class="mockdash-tasks">
                <div class="mockdash-card-head">
                  <h4>Deine Aufgaben</h4>
                  <a href="/Bewerbung" class="dash-link">+ Neue Bewerbung</a>
                </div>
                <% const selectedStatus = activeTaskStatus || 'open'; const statusCount = (s) => {
                  const rows = dash.assignedTasks || [];
                  if (s === 'pending') return rows.filter((t) => ['pending','open'].includes(String(t.status || '').toLowerCase())).length;
                  if (s === 'in_review') return rows.filter((t) => ['accepted','in_review','submitted'].includes(String(t.status || '').toLowerCase())).length;
                  if (s === 'accepted') return rows.filter((t) => ['completed','approved','genehmigt'].includes(String(t.status || '').toLowerCase())).length;
                  return 0;
                }; const statusMatches = (task) => {
                  const s = String(task.status || '').toLowerCase();
                  if (selectedStatus === 'open') return ['pending','open'].includes(s);
                  if (selectedStatus === 'in_review') return ['accepted','in_review','submitted'].includes(s);
                  if (selectedStatus === 'accepted') return ['completed','approved','genehmigt'].includes(s);
                  return true;
                }; const shownTasks = (dash.assignedTasks || []).filter(statusMatches); %>
                <div class="mockdash-tabs">
                  <a class="<%= selectedStatus === 'open' ? 'active' : '' %>" href="/konto/profil?tab=dashboard&taskStatus=open">Offen (<%= statusCount('pending') %>)</a>
                  <a class="<%= selectedStatus === 'in_review' ? 'active' : '' %>" href="/konto/profil?tab=dashboard&taskStatus=in_review">In Prüfung (<%= statusCount('in_review') %>)</a>
                  <a class="<%= selectedStatus === 'accepted' ? 'active' : '' %>" href="/konto/profil?tab=dashboard&taskStatus=accepted">Genehmigt (<%= statusCount('accepted') %>)</a>
                </div>
                <div class="mockdash-table">
                  <% if (!shownTasks || shownTasks.length === 0) { %>
                    <p class="account-muted" style="margin:0;">Noch keine zugewiesenen Aufgaben vorhanden.</p>
                  <% } else { %>
                    <div class="task-grid-head">
                      <span>Aufgabe</span>
                      <span>Verdienst</span>
                      <span>Status</span>
                      <span>Aktion</span>
                    </div>
                    <% shownTasks.slice(0, 6).forEach((task) => { %>
                      <% const s = String(task.status || 'pending').toLowerCase(); const label = (s === 'pending' || s === 'open') ? 'open' : ((s === 'accepted' || s === 'in_review' || s === 'submitted') ? 'in prüfung' : (['completed','approved','genehmigt'].includes(s) ? 'accepted' : s)); %>
                      <article class="task-grid-row">
                        <div class="cell-task">
                          <strong><%= task.template_title || task.title || 'Aufgabe' %></strong>
                          <small class="task-meta" data-due="<%= task.due_date || '' %>">
                            Zeit: <%= task.due_date ? formatRemaining(task.due_date) : 'Unbegrenzt' %>
                          </small>
                        </div>
                        <div class="cell-earn">€ <%= Number(task.payment_amount || 0).toFixed(2) %></div>
                        <div class="cell-status"><span class="badge"><%= label %></span></div>
                        <div class="cell-action">
                          <% if (s === 'pending' || s === 'open') { %>
                            <form method="post" action="/konto/tasks/<%= encodeURIComponent(task.id) %>/accept">
                              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                              <input type="hidden" name="return_tab" value="dashboard" />
                              <input type="hidden" name="return_status" value="open" />
                              <button class="theme-btn task-action-btn" type="submit">Accept</button>
                            </form>
                          <% } else if (s === 'accepted') { %>
                            <form method="post" action="/konto/tasks/<%= encodeURIComponent(task.id) %>/submit">
                              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                              <input type="hidden" name="return_tab" value="dashboard" />
                              <input type="hidden" name="return_status" value="in_review" />
                              <button class="theme-btn task-action-btn" type="submit">Einreichen</button>
                            </form>
                          <% } %>
                        </div>
                      </article>
                    <% }) %>
                  <% } %>
                </div>
              </section>
            </div>

            <aside class="mockdash-right">
              <section class="mockdash-balance">
                <h4>Kontostand</h4>
                <strong class="amount">€ <%= Number(dash.earnedAmount || 0).toFixed(2) %></strong>
                <p><%= dash.completedTasks || 0 %> abgeschlossene Aufgaben · Profil <%= dash.profileCompletion %>%</p><% if (Number(dash.pendingPayoutAmount || 0) > 0) { %><small class="account-muted">Ausstehende Auszahlung: € <%= Number(dash.pendingPayoutAmount || 0).toFixed(2) %></small><% } %>
                <button class="theme-btn" type="button" data-open-payout-modal="1">Auszahlung beantragen</button>
              </section>

              <section class="mockdash-payments">
                <h4>Letzte Zahlungen</h4>
                <% if (!dash.latestPayouts || dash.latestPayouts.length === 0) { %>
                  <p class="account-muted" style="margin:0;">Noch keine Zahlungen vorhanden.</p>
                <% } else { %>
                  <% dash.latestPayouts.slice(0, 3).forEach((payout) => { %>
                    <% const pStatus = String(payout.status || '').toLowerCase(); const pLabel = pStatus === 'requested' ? 'Auszahlung beantragt' : (pStatus === 'processing' ? 'In Bearbeitung' : (pStatus === 'paid' ? 'Ausgezahlt' : 'Abgelehnt')); %>
                    <div class="payment-item">
                      <strong>€ <%= Number(payout.amount || 0).toFixed(2) %></strong>
                      <small><%= pLabel %> · <%= payout.created_at ? new Date(payout.created_at).toLocaleDateString('de-DE') : '' %></small>
                    </div>
                  <% }) %>
                <% } %>
              </section>
            </aside>
          </section>

        <% } else { %>
          <section class="mockdash">
            <aside class="mockdash-side">
              <nav class="mockdash-menu">
                <a href="/konto/profil?tab=dashboard">Dashboard</a>
                <a class="<%= activeTab === 'tasks' ? 'active' : '' %>" href="/konto/profil?tab=tasks">Aufgaben <span class="dot"><%= dash.openTasks %></span></a>
                <a class="<%= activeTab === 'earnings' ? 'active' : '' %>" href="/konto/profil?tab=earnings">Einnahmen</a>
                <a class="<%= activeTab === 'profile' ? 'active' : '' %>" href="/konto/profil?tab=profile">Profil</a>
                <a class="<%= activeTab === 'support' ? 'active' : '' %>" href="/konto/profil?tab=support">Support</a>
                <a class="<%= activeTab === 'documents' ? 'active' : '' %>" href="/konto/profil?tab=documents">Dokumente</a>
              </nav>
              <div class="mockdash-user">
                <strong><%= [user.first_name, user.last_name].filter(Boolean).join(' ') || 'User' %></strong>
                <small><%= user.email %></small>
                <form method="post" action="/konto/logout" class="mockdash-logout-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="mockdash-logout-btn">Logout</button>
                </form>
              </div>
            </aside>

            <div class="mockdash-main">
              <% if (activeTab === 'tasks') { %>
                <header class="account-card-head"><h3>Aufgaben</h3><p class="account-muted">Deine zugewiesenen Aufgaben aus MagicVics.</p></header>
                <section class="mockdash-tasks">
                  <% if (!dash.assignedTasks || dash.assignedTasks.length === 0) { %>
                    <p class="account-muted" style="margin:0;">Aktuell sind keine Aufgaben zugewiesen.</p>
                  <% } else { %>
                    <div class="mockdash-table">
                      <% dash.assignedTasks.forEach((task) => { %>
                        <% const s = String(task.status || 'pending').toLowerCase(); const label = (s === 'pending' || s === 'open') ? 'open' : ((s === 'accepted' || s === 'in_review' || s === 'submitted') ? 'in prüfung' : (['completed','approved','genehmigt'].includes(s) ? 'accepted' : s)); %>
                        <details class="mockdash-row-details">
                          <summary class="mockdash-row">
                            <div>
                              <strong><%= task.template_title || task.title || 'Aufgabe' %></strong>
                              <small class="task-meta" data-due="<%= task.due_date || '' %>" data-earn="<%= Number(task.payment_amount || 0).toFixed(2) %>">
                                Zeit: <%= task.due_date ? formatRemaining(task.due_date) : 'Unbegrenzt' %> · Verdienst: € <%= Number(task.payment_amount || 0).toFixed(2) %>
                              </small>
                            </div>
                            <span class="badge"><%= label %></span>
                          </summary>
                          <div class="task-detail-body">
                            <p class="account-muted"><%= task.template_description || 'Keine Beschreibung vorhanden.' %></p>
                            <% if (task.template_steps && task.template_steps.length) { %>
                              <ol>
                                <% task.template_steps.forEach((step) => { %>
                                  <li><strong><%= step.title || 'Schritt' %>:</strong> <%= step.description || '' %></li>
                                <% }) %>
                              </ol>
                            <% } %>
                            <% if (s === 'pending' || s === 'open') { %>
                              <form method="post" action="/konto/tasks/<%= encodeURIComponent(task.id) %>/accept" class="task-submit-form">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                <input type="hidden" name="return_tab" value="tasks" />
                                <input type="hidden" name="return_status" value="all" />
                                <button class="theme-btn task-action-btn" type="submit">Accept</button>
                              </form>
                            <% } else if (s === 'accepted') { %>
                              <form method="post" action="/konto/tasks/<%= encodeURIComponent(task.id) %>/submit" class="task-submit-form">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                <input type="hidden" name="return_tab" value="tasks" />
                                <input type="hidden" name="return_status" value="all" />
                                <button class="theme-btn task-action-btn" type="submit">Einreichen</button>
                              </form>
                            <% } %>
                          </div>
                        </details>
                      <% }) %>
                    </div>
                  <% } %>
                </section>
              <% } else if (activeTab === 'earnings') { %>
                <header class="account-card-head"><h3>Einnahmen</h3><p class="account-muted">Uebersicht ueber Verdienst, Auszahlungen und Aufgabenleistung.</p></header>
                <section class="earnings-wrap">
                  <div class="earnings-kpis">
                    <article class="earnings-kpi-card">
                      <span>Gesamt verdient</span>
                      <strong>€ <%= Number(dash.totalEarnedAmount || 0).toFixed(2) %></strong>
                    </article>
                    <article class="earnings-kpi-card">
                      <span>Ausstehende Auszahlungen</span>
                      <strong>€ <%= Number(dash.pendingPayoutAmount || 0).toFixed(2) %></strong>
                    </article>
                    <article class="earnings-kpi-card">
                      <span>Verfuegbarer Kontostand</span>
                      <strong>€ <%= Number(dash.earnedAmount || 0).toFixed(2) %></strong>
                    </article>
                    <article class="earnings-kpi-card">
                      <span>Abgeschlossene Aufgaben</span>
                      <strong><%= Number(dash.completedTasks || 0) %></strong>
                    </article>
                  </div>

                  <div class="earnings-grid">
                    <section class="earnings-card">
                      <h4>Letzte Aufgaben-Verdienste</h4>
                      <% const completedTasksForEarnings = (dash.assignedTasks || []).filter((task) => ['completed', 'approved', 'genehmigt'].includes(String(task?.status || '').toLowerCase())); %>
                      <% if (!completedTasksForEarnings.length) { %>
                        <p class="account-muted" style="margin:0;">Noch keine abgeschlossenen Aufgaben.</p>
                      <% } else { %>
                        <div class="earnings-list">
                          <% completedTasksForEarnings.slice(0, 6).forEach((task) => { %>
                            <article class="earnings-item">
                              <div>
                                <strong><%= task.template_title || task.task_title || 'Aufgabe' %></strong>
                                <small><%= task.completed_at ? new Date(task.completed_at).toLocaleDateString('de-DE') : 'Genehmigt' %></small>
                              </div>
                              <span>€ <%= Number(task.payment_amount || 0).toFixed(2) %></span>
                            </article>
                          <% }) %>
                        </div>
                      <% } %>
                    </section>

                    <section class="earnings-card">
                      <h4>Auszahlungsverlauf</h4>
                      <% if (!dash.latestPayouts || !dash.latestPayouts.length) { %>
                        <p class="account-muted" style="margin:0;">Noch keine Auszahlungsanfragen vorhanden.</p>
                      <% } else { %>
                        <div class="earnings-list">
                          <% dash.latestPayouts.slice(0, 6).forEach((payout) => { %>
                            <% const pStatus = String(payout.status || '').toLowerCase(); const pLabel = pStatus === 'requested' ? 'Beantragt' : (pStatus === 'processing' ? 'In Bearbeitung' : (pStatus === 'paid' ? 'Ausgezahlt' : 'Abgelehnt')); %>
                            <article class="earnings-item">
                              <div>
                                <strong><%= pLabel %></strong>
                                <small><%= payout.created_at ? new Date(payout.created_at).toLocaleDateString('de-DE') : '' %></small>
                              </div>
                              <span>€ <%= Number(payout.amount || 0).toFixed(2) %></span>
                            </article>
                          <% }) %>
                        </div>
                      <% } %>
                    </section>
                  </div>
                </section>
              <% } else if (activeTab === 'support') { %>
                <header class="account-card-head"><h3>Support</h3><p class="account-muted">Brauchst du Hilfe bei Aufgaben, Auszahlung oder deinem Profil?</p></header>
                <section class="mockdash-tasks" style="display:grid; gap:12px;">
                  <p class="account-muted" style="margin:0;">Unser Team hilft dir schnell weiter. Nutze den Kontakt-Button, um direkt zur Kontaktseite zu gehen.</p>
                  <div class="account-actions" style="margin:0;">
                    <a class="theme-btn" href="/Kontakt">Kontaktseite öffnen <i class="fa-solid fa-arrow-right"></i></a>
                  </div>
                </section>
              <% } else if (activeTab === 'profile') { %>
                <header class="account-card-head">
                  <h3>Persönliche Daten</h3>
                  <p class="account-muted">Pflegen Sie Ihre Kontaktdaten und halten Sie Ihr Profil aktuell.</p>
                </header>
                <form method="post" action="/konto/profil">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <h4 class="account-section-title">Basisdaten</h4>
                  <div class="account-form-grid">
                    <div class="account-field"><label for="pf-first">Vorname</label><input id="pf-first" name="first_name" required value="<%= user.first_name || '' %>" /></div>
                    <div class="account-field"><label for="pf-last">Nachname</label><input id="pf-last" name="last_name" required value="<%= user.last_name || '' %>" /></div>
                    <div class="account-field"><label for="pf-email">E-Mail</label><input id="pf-email" name="email" type="email" required value="<%= user.email || '' %>" /></div>
                    <div class="account-field"><label for="pf-phone">Telefon</label><input id="pf-phone" name="phone" value="<%= user.phone || '' %>" /></div>
                    <div class="account-field"><label for="pf-birth">Geburtsdatum</label><input id="pf-birth" name="birth_date" type="date" value="<%= birthDateInput %>" /></div>
                    <div class="account-field"><label for="pf-pass">Neues Passwort (optional)</label><input id="pf-pass" name="new_password" type="password" /></div>
                  </div>
                  <h4 class="account-section-title">Adressdaten</h4>
                  <div class="account-form-grid">
                    <div class="account-field full"><label for="pf-address">Anschrift</label><input id="pf-address" name="address_line" value="<%= user.address_line || '' %>" /></div>
                    <div class="account-field"><label for="pf-zip">PLZ</label><input id="pf-zip" name="zip" value="<%= user.zip || '' %>" /></div>
                    <div class="account-field"><label for="pf-city">Stadt</label><input id="pf-city" name="city" value="<%= user.city || '' %>" /></div>
                    <div class="account-field"><label for="pf-country">Land</label><input id="pf-country" name="country" value="<%= user.country || '' %>" /></div>
                  </div>
                  <div class="account-actions account-actions-end"><button class="theme-btn" type="submit">Profil speichern <i class="fa-solid fa-arrow-right"></i></button></div>
                </form>
              <% } else { %>
                <header class="account-card-head">
                  <h3>Dokumente</h3>
                  <p class="account-muted">Laden Sie angeforderte Unterlagen hoch, zum Beispiel Ausweis oder Gehaltsnachweise.</p>
                </header>
                <form method="post" action="/konto/profil/dokumente?_csrf=<%= encodeURIComponent(csrfToken) %>" enctype="multipart/form-data">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <div class="account-form-grid">
                    <div class="account-field">
                      <label for="doc-type">Dokumenttyp</label>
                      <select id="doc-type" name="doc_type" required>
                        <option value="">Bitte wählen</option>
                        <% docTypeOptions.forEach((opt) => { %>
                          <option value="<%= opt.value %>"><%= opt.label %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="account-field">
                      <label for="doc-file">Datei (PDF/JPG/PNG/WEBP, max. 10 MB)</label>
                      <input id="doc-file" name="document_file" type="file" required />
                    </div>
                    <div class="account-actions">
                      <button class="theme-btn" type="submit">Dokument hochladen <i class="fa-solid fa-arrow-up-from-bracket"></i></button>
                    </div>
                  </div>
                </form>
                <div class="account-doc-list">
                  <% if (!documents || documents.length === 0) { %>
                    <p class="account-muted" style="margin-top:14px;">Noch keine Dokumente hochgeladen.</p>
                  <% } else { %>
                    <% documents.forEach((doc) => { %>
                      <article class="account-doc-item">
                        <div>
                          <h5><%= doc.doc_type_label %></h5>
                          <p><%= doc.original_name %></p>
                          <small><%= new Date(doc.created_at).toLocaleString('de-DE') %> · <%= Math.ceil(doc.size_bytes / 1024) %> KB</small>
                        </div>
                        <a class="btn btn-secondary" href="<%= doc.file_url %>" target="_blank" rel="noopener noreferrer">Ansehen</a>
                      </article>
                    <% }) %>
                  <% } %>
                </div>
              <% } %>
            </div>

            <aside class="mockdash-right">
              <section class="mockdash-balance">
                <h4>Kontostand</h4>
                <strong class="amount">€ <%= Number(dash.earnedAmount || 0).toFixed(2) %></strong>
                <p><%= dash.completedTasks || 0 %> abgeschlossene Aufgaben · Profil <%= dash.profileCompletion %>%</p><% if (Number(dash.pendingPayoutAmount || 0) > 0) { %><small class="account-muted">Ausstehende Auszahlung: € <%= Number(dash.pendingPayoutAmount || 0).toFixed(2) %></small><% } %>
                <button class="theme-btn" type="button" data-open-payout-modal="1">Auszahlung beantragen</button>
              </section>
              <section class="mockdash-payments">
                <h4>Letzte Zahlungen</h4>
                <% if (!dash.latestPayouts || dash.latestPayouts.length === 0) { %>
                  <p class="account-muted" style="margin:0;">Noch keine Zahlungen vorhanden.</p>
                <% } else { %>
                  <% dash.latestPayouts.slice(0, 3).forEach((payout) => { %>
                    <% const pStatus = String(payout.status || '').toLowerCase(); const pLabel = pStatus === 'requested' ? 'Auszahlung beantragt' : (pStatus === 'processing' ? 'In Bearbeitung' : (pStatus === 'paid' ? 'Ausgezahlt' : 'Abgelehnt')); %>
                    <div class="payment-item">
                      <strong>€ <%= Number(payout.amount || 0).toFixed(2) %></strong>
                      <small><%= pLabel %> · <%= payout.created_at ? new Date(payout.created_at).toLocaleDateString('de-DE') : '' %></small>
                    </div>
                  <% }) %>
                <% } %>
              </section>
            </aside>
          </section>
        <% } %>
      </div>
    </div>
  </div>
</section>

<style>
  .mockdash-logout-form { margin-top: 8px; }
  .mockdash-logout-btn { border: 1px solid rgba(255,255,255,0.3); background: rgba(255,255,255,0.08); color: #fff; border-radius: 8px; padding: 6px 10px; font-size: 12px; line-height: 1; cursor: pointer; }
  .mockdash-logout-btn:hover { background: rgba(255,255,255,0.18); }

  .task-meta, small.task-meta { font-size: 14px !important; line-height: 1.35; color: #6a7890; }
  .earnings-wrap { display: grid; gap: 16px; }
  .earnings-kpis { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; }
  .earnings-kpi-card { border: 1px solid #e1e7f2; background: #fff; border-radius: 12px; padding: 12px 14px; display: grid; gap: 4px; }
  .earnings-kpi-card span { font-size: 12px; color: #6a7890; }
  .earnings-kpi-card strong { font-size: 24px; line-height: 1.15; color: #0f1f3b; }
  .earnings-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .earnings-card { border: 1px solid #e1e7f2; background: #fff; border-radius: 12px; padding: 14px; }
  .earnings-card h4 { margin: 0 0 10px; font-size: 16px; color: #0f1f3b; }
  .earnings-list { display: grid; gap: 8px; }
  .earnings-item { display: flex; align-items: center; justify-content: space-between; gap: 10px; border: 1px solid #edf2fb; border-radius: 10px; padding: 10px 12px; background: #fbfdff; }
  .earnings-item strong { display: block; font-size: 14px; color: #112647; }
  .earnings-item small { color: #6a7890; font-size: 12px; }
  .earnings-item span { font-weight: 700; color: #123160; }
  @media (max-width: 980px) {
    .earnings-kpis { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .earnings-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .earnings-kpis { grid-template-columns: 1fr; }
  }

  .payout-modal[hidden] { display: none !important; }
  .payout-modal { position: fixed; inset: 0; z-index: 1200; display: flex; align-items: center; justify-content: center; padding: 20px; }
  .payout-modal__backdrop { position: absolute; inset: 0; background: rgba(8, 15, 32, 0.55); }
  .payout-modal__dialog { position: relative; width: 100%; max-width: 560px; background: #fff; border-radius: 16px; box-shadow: 0 24px 70px rgba(0,0,0,0.28); overflow: hidden; }
  .payout-modal__head { display: flex; align-items: center; justify-content: space-between; padding: 18px 22px; border-bottom: 1px solid #e8edf5; }
  .payout-modal__head h3 { margin: 0; font-size: 22px; }
  .payout-modal__close { border: 0; background: transparent; font-size: 30px; line-height: 1; color: #5b6f8f; cursor: pointer; }
  .payout-modal__body { padding: 20px 22px 24px; display: grid; gap: 12px; }
  .payout-modal__note { margin-top: 4px; margin-bottom: 0; font-size: 14px; line-height: 1.5; background: #f6f9ff; border: 1px solid #dce8ff; border-radius: 10px; padding: 10px 12px; }
</style>

<div class="payout-modal" id="payout-modal" hidden>
  <div class="payout-modal__backdrop" data-close-payout-modal="1"></div>
  <div class="payout-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="payout-modal-title">
    <div class="payout-modal__head">
      <h3 id="payout-modal-title">Auszahlung beantragen</h3>
      <button type="button" class="payout-modal__close" data-close-payout-modal="1" aria-label="Schliessen">&times;</button>
    </div>
    <form method="post" action="/konto/payout/request" class="payout-modal__body">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="return_tab" value="<%= activeTab || 'dashboard' %>" />
      <input type="hidden" name="return_status" value="<%= activeTaskStatus || 'open' %>" />
      <input type="hidden" name="payout_amount" value="<%= Number(dash?.earnedAmount || 0).toFixed(2) %>" />

      <div class="account-field">
        <label for="payout-name">Name</label>
        <input id="payout-name" name="account_holder_name" required autocomplete="name" />
      </div>

      <div class="account-field">
        <label for="payout-iban">IBAN</label>
        <input id="payout-iban" name="iban" required autocomplete="off" inputmode="latin" placeholder="DE00000000000000000000" />
      </div>

      <div class="account-field">
        <label for="payout-bic">BIC</label>
        <input id="payout-bic" name="bic" required autocomplete="off" placeholder="ABCDEFGHXXX" />
      </div>

      <p class="account-muted payout-modal__note">Auszahlungen werden innerhalb von 30 Tagen nach Genehmigung der Aufgabe bearbeitet. Die Auszahlung erfolgt per Banküberweisung auf das hinterlegte Konto.</p>    </form>
  </div>
</div>

<script>
  (function () {
    const nodes = document.querySelectorAll('.task-meta[data-due]');

    function fmtRemaining(dueIso) {
      if (!dueIso) return 'Unbegrenzt';
      const due = new Date(dueIso);
      if (Number.isNaN(due.getTime())) return 'Unbegrenzt';
      const diff = due.getTime() - Date.now();
      if (diff <= 0) return 'Abgelaufen';
      const mins = Math.floor(diff / 60000);
      const days = Math.floor(mins / 1440);
      const hours = Math.floor((mins % 1440) / 60);
      const minutes = mins % 60;
      if (days > 0) return `${days}d ${hours}h ${minutes}m`;
      if (hours > 0) return `${hours}h ${minutes}m`;
      return `${minutes}m`;
    }

    function refresh() {
      nodes.forEach((el) => {
        const due = el.getAttribute('data-due') || '';
        const txt = fmtRemaining(due);
        const earn = el.getAttribute('data-earn');
        el.textContent = earn ? `Zeit: ${txt} · Verdienst: € ${earn}` : `Zeit: ${txt}`;
      });
    }

    if (nodes.length) {
      refresh();
      setInterval(refresh, 60000);
    }

    const modal = document.getElementById('payout-modal');
    const openButtons = document.querySelectorAll('[data-open-payout-modal]');
    const closeButtons = document.querySelectorAll('[data-close-payout-modal]');

    if (modal && openButtons.length) {
      const openModal = () => {
        modal.hidden = false;
        document.body.style.overflow = 'hidden';
      };

      const closeModal = () => {
        modal.hidden = true;
        document.body.style.overflow = '';
      };

      openButtons.forEach((btn) => btn.addEventListener('click', openModal));
      closeButtons.forEach((btn) => btn.addEventListener('click', closeModal));
      document.addEventListener('keydown', (ev) => {
        if (ev.key === 'Escape' && !modal.hidden) closeModal();
      });

      const ibanInput = document.getElementById('payout-iban');
      const bicInput = document.getElementById('payout-bic');
      if (ibanInput) {
        ibanInput.addEventListener('input', () => {
          ibanInput.value = String(ibanInput.value || '').replace(/\s+/g, '').toUpperCase();
        });
      }
      if (bicInput) {
        bicInput.addEventListener('input', () => {
          bicInput.value = String(bicInput.value || '').replace(/\s+/g, '').toUpperCase();
        });
      }
    }
  })();
</script>

